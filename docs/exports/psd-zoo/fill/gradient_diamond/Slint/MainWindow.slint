export component MainWindow inherits Window {
    height: 200px;
    title: "";
    width: 200px;
    x: 0px;
    y: 0px;
    Image {
        height: 200px;
        image-fit: contain;
        source: @image-url("images/background.png");
        width: 200px;
        x: 0px;
        y: 0px;
    }
    Rectangle {
        height: 200px;
        width: 200px;
        x: 0px;
        y: 0px;
        Rectangle {
            background: @radial-gradient(circle, #00ffff 0%, #ff0080 70.7107%, #ff0080 100%);
            height: 200px;
            width: 200px;
            x: 0px;
            y: 0px;
        }
    }
}
